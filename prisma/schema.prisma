// prisma/schema.prisma
generator client {
  provider = "prisma-client"
  output   = "./generated/client"  // 正确位置：在 generator 块里
}

// 必须保留的 datasource 块
datasource db {
  provider = "sqlite"

}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  avatar        String?
  balance       Float     @default(10)      // 用户余额
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]                      // 关联订单
  messages      Message[]
}

// ✅ 新增：充值套餐模型
model RechargePackage {
  id            String    @id @default(cuid())
  name          String    @unique                   // 套餐名（如"30元套餐"）
  amount        Float                        // 金额
  bonus         Float     @default(0)         // 赠送金额
  description   String?                       // 描述
  sortOrder     Int       @default(0)         // 排序
  isActive      Boolean   @default(true)      // 是否上架
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]                       // 关联订单
}

// ✅ 新增：订单模型
model Order {
  id            String    @id @default(cuid())
  orderNo       String    @unique             // 订单号（业务用）
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  packageId     String?                        // 关联套餐（可为空，支持自定义金额）
  package       RechargePackage? @relation(fields: [packageId], references: [id])
  amount        Float                         // 支付金额
  bonus         Float     @default(0)          // 赠送金额
  paymentMethod String    @default("alipay")   // alipay/wechat
  status        String    @default("PENDING")  // PENDING/SUCCESS/FAILED
  tradeNo       String?                        // 支付平台交易号
  payTime       DateTime?                      // 支付时间
  expireTime    DateTime?                       // 订单过期时间
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([orderNo])
}

model Message {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  content       String
  tokens        Int?
  cost          Float?
  createdAt     DateTime  @default(now())
}